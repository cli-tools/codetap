{
  "name": "codetap",
  "displayName": "CodeTap",
  "description": "Discover and connect to CodeTap VS Code Server sessions in containers",
  "version": "0.6.1",
  "publisher": "cli-tools",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "https://github.com/cli-tools/codetap.git"
  },
  "homepage": "https://github.com/cli-tools/codetap",
  "bugs": {
    "url": "https://github.com/cli-tools/codetap/issues"
  },
  "engines": {
    "vscode": "^1.87.0"
  },
  "enabledApiProposals": [
    "resolvers"
  ],
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onResolveRemoteAuthority:codetap",
    "onView:codetap.sessions"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "files": [
    "out/**/*.js",
    "package.json",
    "README.md",
    "LICENSE",
    "icon.png"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codetap",
          "title": "CodeTap",
          "icon": "$(remote)"
        }
      ]
    },
    "views": {
      "codetap": [
        {
          "id": "codetap.sessions",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "codetap.connect",
        "title": "CodeTap: Connect to Session",
        "icon": "$(plug)"
      },
      {
        "command": "codetap.refresh",
        "title": "CodeTap: Refresh Sessions",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codetap.refresh",
          "when": "view == codetap.sessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codetap.connect",
          "when": "view == codetap.sessions && viewItem == aliveSession",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "CodeTap",
      "properties": {
        "codetap.socketDir": {
          "type": "string",
          "default": "/dev/shm/codetap",
          "description": "Directory to scan for CodeTap session sockets (used when running on the local/UI side)"
        },
        "codetap.remoteSocketDir": {
          "type": "string",
          "default": "/dev/shm/codetap",
          "description": "Directory to scan for CodeTap session sockets when running on the remote/workspace side"
        },
        "codetap.pollInterval": {
          "type": "number",
          "default": 3000,
          "description": "Polling interval in milliseconds for session discovery"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --out codetap.vsix",
    "publish": "vsce publish --azure-credential --allow-proposed-apis resolvers"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.87.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
